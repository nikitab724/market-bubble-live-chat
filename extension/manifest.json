{
  "manifest_version": 3,
  "name": "Market Bubble X Bridge",
  "version": "1.0",
  "description": "Captures X livestream chat and sends it to the Market Bubble dashboard",
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Market Bubble X Bridge"
  }
}
